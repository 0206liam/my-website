<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <title>AI 智能決策助理</title>
    <style>
        body { font-family: sans-serif; background: #f4f4f9; display: flex; justify-content: center; align-items: center; height: 100vh; margin: 0; }
        #chat-box { width: 400px; height: 500px; background: white; border-radius: 10px; box-shadow: 0 5px 15px rgba(0,0,0,0.1); display: flex; flex-direction: column; }
        #messages { flex: 1; padding: 20px; overflow-y: auto; border-bottom: 1px solid #eee; }
        .msg { margin-bottom: 10px; padding: 8px 12px; border-radius: 15px; max-width: 80%; }
        .user { background: #007bff; color: white; align-self: flex-end; margin-left: auto; }
        .ai { background: #e9e9eb; color: #333; }
        #input-area { padding: 15px; display: flex; }
        input { flex: 1; padding: 10px; border: 1px solid #ddd; border-radius: 5px; outline: none; }
        button { margin-left: 10px; padding: 10px 20px; background: #007bff; color: white; border: none; border-radius: 5px; cursor: pointer; }
    </style>
</head>
<body>
    <div id="chat-box">
        <div id="messages">
            <div class="msg ai">你好，我是量子決策 AI，請輸入你的問題，我將為你進行深度運算。</div>
        </div>
        <div id="input-area">
            <input type="text" id="userInput" placeholder="輸入訊息...">
            <button onclick="sendMessage()">發送</button>
        </div>
    </div>

<script>
    // 這裡填入你的 GitHub 配置 (由 A 端產生後填入或透過 URL 參數傳遞)
    const GITHUB_TOKEN = "你的_GITHUB_TOKEN"; 
    const GIST_ID = "你的_GIST_ID";

    let userId = localStorage.getItem('chat_user_id');

    async function sendMessage() {
        const input = document.getElementById('userInput');
        const text = input.value.trim();
        if (!text) return;

        // 第一次發送，產生 ID
        if (!userId) {
            const random4 = Math.floor(1000 + Math.random() * 9000);
            // 這裡簡單處理用戶編號，實際運作建議從 Gist 獲取最後編號
            const userSeq = "001"; 
            userId = `${random4}${userSeq}`;
            localStorage.setItem('chat_user_id', userId);
        }

        appendMessage(text, 'user');
        input.value = '';

        const timestamp = new Date().toISOString();
        await uploadToCloud(userId, text, timestamp);
    }

    function appendMessage(text, side) {
        const div = document.createElement('div');
        div.className = `msg ${side}`;
        div.innerText = text;
        document.getElementById('messages').appendChild(div);
    }

    async function uploadToCloud(id, msg, time) {
        // 獲取現有數據
        const response = await fetch(`https://api.github.com/gists/${GIST_ID}`, {
            headers: { "Authorization": `token ${GITHUB_TOKEN}` }
        });
        const gistData = await response.json();
        let content = JSON.parse(gistData.files["chats.json"].content || "[]");
        
        content.push({ id, msg, time, role: 'user' });

        await fetch(`https://api.github.com/gists/${GIST_ID}`, {
            method: "PATCH",
            headers: { "Authorization": `token ${GITHUB_TOKEN}`, "Content-Type": "application/json" },
            body: JSON.stringify({
                files: { "chats.json": { content: JSON.stringify(content) } }
            })
        });
    }
</script>
</body>
</html>
